# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://xbuild:xbuild123@localhost:5432/xbuild?schema=public"
DIRECT_URL="postgresql://xbuild:xbuild123@localhost:5432/xbuild"

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# ─── Google OAuth ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:3000/auth/google/callback"

# ─── S3 / MinIO ──────────────────────────────────────────────────────────────
S3_ENDPOINT="http://localhost:9000"
S3_REGION="ap-southeast-1"
S3_BUCKET="xbuild"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_FORCE_PATH_STYLE="true"

# ─── AI ──────────────────────────────────────────────────────────────────────
AI_PROVIDER="openai"
AI_BASE_URL="https://api.openai.com/v1"
AI_API_KEY=""
AI_DEFAULT_MODEL="gpt-4o-mini"
AI_EMBEDDING_MODEL="text-embedding-3-small"

# ─── Encryption (AES-256 for settings) ───────────────────────────────────────
ENCRYPTION_KEY="change-me-32-byte-hex-key-here!!"

# ─── SMTP ────────────────────────────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="XBuild <noreply@xbuild.vn>"

# ─── App ─────────────────────────────────────────────────────────────────────
APP_URL="http://localhost:5173"
API_PORT="3000"
NODE_ENV="development"
